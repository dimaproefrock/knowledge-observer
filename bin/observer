#!/usr/bin/env bash
# knowledge-observer launcher.
#
# Resolves the correct `observer` binary for this OS/arch and execs it, so a SINGLE
# command string in the plugin's hooks and MCP config works on every platform even
# though the native binary differs per OS. Resolution order:
#   1. $OBSERVER_BIN            (explicit override; dev / CI)
#   2. a binary next to this launcher (locally built: observer.exe / observer-native)
#   3. the per-OS GitHub Release asset, cached in $CLAUDE_PLUGIN_DATA (downloaded once)
#
# Invoked via `bash` from mcpServers (robust on Windows, where a no-extension script
# would not be directly spawnable) and via the shell from hooks.
set -e

here="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# 1) explicit override
if [ -n "${OBSERVER_BIN:-}" ] && [ -x "${OBSERVER_BIN}" ]; then
  exec "${OBSERVER_BIN}" "$@"
fi

# detect platform → release-asset name + local-dev binary name
os="$(uname -s)"; arch="$(uname -m)"
case "${os}" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT)
    asset="observer-windows-x64.exe"; localname="observer.exe" ;;
  Darwin)
    case "${arch}" in arm64|aarch64) asset="observer-macos-arm64" ;; *) asset="observer-macos-x64" ;; esac
    localname="observer-native" ;;
  Linux)
    asset="observer-linux-x64"; localname="observer-native" ;;
  *)
    echo "knowledge-observer: unsupported OS '${os}'" >&2; exit 1 ;;
esac

# 2) locally-built binary sitting next to this launcher (manual / --plugin-dir dev)
if [ -x "${here}/${localname}" ]; then
  exec "${here}/${localname}" "$@"
fi

# 3) per-OS release binary, cached in the plugin data dir (download once per version)
ver="$(cat "${here}/../VERSION" 2>/dev/null | tr -d ' \t\r\n')"
data="${CLAUDE_PLUGIN_DATA:-${HOME}/.knowledge-observer}"
cached="${data}/observer-${ver}-${asset}"
if [ ! -x "${cached}" ]; then
  if [ -z "${ver}" ]; then
    echo "knowledge-observer: no VERSION file and no local binary found" >&2; exit 1
  fi
  mkdir -p "${data}"
  url="https://github.com/dimaproefrock/knowledge-observer/releases/download/${ver}/${asset}"
  echo "knowledge-observer: fetching ${asset} (${ver})…" >&2
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${url}" -o "${cached}.tmp"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "${cached}.tmp" "${url}"
  else
    echo "knowledge-observer: need curl or wget to fetch the binary" >&2; exit 1
  fi
  chmod +x "${cached}.tmp"
  mv "${cached}.tmp" "${cached}"
fi
exec "${cached}" "$@"
